{
  "name": "docker-deploy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "turbo run migrate --filter=@repo/db",
    "db:generate": "turbo run generate --filter=@repo/db",
    "start:backend": "turbo run dev --filter=backend",
    "start:ws": "turbo run dev --filter=ws-backend",
    "start:web": "turbo run start --filter=web"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
